# Chiavi AI del gestionale demo — NON committare il .env reale.
# Su Railway impostale come Variables del servizio.
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# Limiti demo pubblica (opzionali — questi sono i default nel codice)
DEMO_FREE_USES=3            # prove AI per singolo visitatore (IP)
DEMO_GLOBAL_DAILY_CAP=150   # tetto globale giornaliero (protezione chiavi)
FLASK_ENV=production
